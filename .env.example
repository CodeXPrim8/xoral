# XORAL — Supabase environment variables
# Copy to .env.local and fill in values from your Supabase project dashboard.
# Full guide: supabase/SETUP.md

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the anon key (eyJ...) or publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Production: https://xoral-iota.vercel.app
# Auth Site URL: https://xoral-iota.vercel.app
# Auth Redirect URLs: https://xoral-iota.vercel.app/** and http://localhost:3000/**
